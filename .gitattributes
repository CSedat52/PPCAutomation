# ============================================
# Amazon PPC Otomasyon Sistemi — .gitattributes
# Satir sonlarini repoda LF'e sabitler (VPS = Ubuntu/LF).
# Windows'ta dosyalar CRLF olsa bile commit'ler LF saklanir,
# boylece "tum dosyalar degisti" gurultusu bir daha olmaz.
# ============================================

# Varsayilan: metin olarak algilanan her sey repoda LF
* text=auto eol=lf

# Kod / yapilandirma — acikca LF
*.py        text eol=lf
*.json      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.toml      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.env*       text eol=lf

# Ikili dosyalar — asla dokunma
*.xlsx      binary
*.xls       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.zip       binary
*.pyc       binary
*.ico       binary
